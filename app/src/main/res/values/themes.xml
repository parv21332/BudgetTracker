<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Main App Theme -->
    <style name="Theme.BudgetTracker" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorError">@color/error_red</item>
        <item name="colorOnError">@color/on_error</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.BudgetTracker.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.BudgetTracker</item>
    </style>

    <!-- Toolbar style -->
    <style name="Widget.BudgetTracker.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/primary</item>
        <item name="titleTextColor">@color/on_primary</item>
        <item name="navigationIconTint">@color/on_primary</item>
    </style>

    <!-- Card Style - elevated with subtle shadow -->
    <style name="Widget.BudgetTracker.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="cardBackgroundColor">@color/surface</item>
    </style>

    <!-- Card Style - No border, elevated -->
    <style name="Widget.BudgetTracker.Card.NoBorder" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">6dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- FAB Style -->
    <style name="Widget.BudgetTracker.FAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="tint">@color/on_primary</item>
        <item name="backgroundTint">@color/primary</item>
    </style>

    <!-- Input field style - Filled box -->
    <style name="Widget.BudgetTracker.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="boxBackgroundColor">@color/surface</item>
    </style>

    <!-- Button Style - Primary with rounded corners -->
    <style name="Widget.BudgetTracker.Button" parent="Widget.Material3.Button">
        <item name="android:minHeight">54dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Button Style - Outlined -->
    <style name="Widget.BudgetTracker.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">54dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="strokeColor">@color/border</item>
        <item name="android:textSize">15sp</item>
        <item name="strokeWidth">1.5dp</item>
    </style>

    <!-- Transaction item style -->
    <style name="Widget.BudgetTracker.TransactionCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="cardBackgroundColor">@color/surface</item>
    </style>

    <!-- Chip filter style -->
    <style name="Widget.BudgetTracker.FilterChip" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">20dp</item>
        <item name="chipBackgroundColor">@color/surface</item>
        <item name="checkedIconVisible">false</item>
        <item name="chipStrokeWidth">1.5dp</item>
        <item name="chipStrokeColor">@color/border</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
    </style>

</resources>
